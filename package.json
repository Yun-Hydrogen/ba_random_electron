{
  "name": "blue-random-electron",
  "version": "26.06.14",
  "description": "蔚蓝点名-仿《蔚蓝档案》学员招募的随机点名工具",
  "author": "HydrogenRua",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.hydrogenrua.blue-random",
    "productName": "Blue Random",
    "extraFiles": [
      {
        "from": "third_party/uiaccess.dll",
        "to": "uiaccess.dll"
      },
      "THIRD_PARTY_NOTICES/RunUIAccess-MIT.txt"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "zip",
      "icon": "public/image/app.ico"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "node build/prepare-uiaccess.js && vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.15.0",
    "js-yaml": "^4.1.0",
    "vue": "^3.5.17",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
